{
    "experimentalServices": {
        "frontend": {
            "routePrefix": "/",
            "framework": "vite"
        },
        "backend": {
            "entrypoint": "backend",
            "routePrefix": "/_/backend"
        }
    },
    "rewrites": [
        { "source": "/api/:path*", "destination": "/_/backend/api/:path*" },
        { "source": "/ws/:path*", "destination": "/_/backend/ws/:path*" }
    ]
}
